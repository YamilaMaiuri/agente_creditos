{
  "openapi": "3.1.0",
  "info": {
    "title": "BNA - API Créditos Hipotecarios",
    "description": "API para consultar RENAPER, BCRA y AFIP en el flujo de solicitud de créditos hipotecarios del BNA",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://creditos-app.2925a7i62z1m.us-east.codeengine.appdomain.cloud",
      "description": "Code Engine - Producción"
    }
  ],
  "paths": {
    "/renaper/{dni}": {
      "get": {
        "tags": ["RENAPER"],
        "summary": "Consultar RENAPER por DNI",
        "description": "Devuelve nombre completo, CUIL, fecha de nacimiento y domicilio registrado en el padrón del RENAPER.",
        "operationId": "consultar_renaper",
        "parameters": [
          {
            "name": "dni",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "DNI"
            },
            "description": "Número de DNI del solicitante (solo dígitos, sin puntos ni espacios)"
          }
        ],
        "responses": {
          "200": {
            "description": "Datos de identidad del solicitante",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RenaperResponse"
                }
              }
            }
          },
          "404": {
            "description": "DNI no encontrado en el padrón RENAPER"
          }
        }
      }
    },
    "/bcra/{cuil}": {
      "get": {
        "tags": ["BCRA"],
        "summary": "Consultar BCRA por CUIL",
        "description": "Devuelve la situación crediticia, score, deudas activas e informes negativos en los últimos 12 meses.",
        "operationId": "consultar_bcra",
        "parameters": [
          {
            "name": "cuil",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "CUIL"
            },
            "description": "CUIL del solicitante en formato XX-XXXXXXXX-X"
          }
        ],
        "responses": {
          "200": {
            "description": "Situación crediticia del solicitante",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BcraResponse"
                }
              }
            }
          },
          "404": {
            "description": "CUIL no encontrado en el registro BCRA"
          }
        }
      }
    },
    "/afip/{cuil}": {
      "get": {
        "tags": ["AFIP"],
        "summary": "Consultar AFIP por CUIL",
        "description": "Devuelve la categoría tributaria, empleador o actividad según corresponda, estado fiscal y fecha de inscripción en AFIP/ARCA.",
        "operationId": "consultar_afip",
        "parameters": [
          {
            "name": "cuil",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "CUIL"
            },
            "description": "CUIL del solicitante en formato XX-XXXXXXXX-X"
          }
        ],
        "responses": {
          "200": {
            "description": "Situación impositiva del solicitante",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AfipResponse"
                }
              }
            }
          },
          "404": {
            "description": "CUIL no encontrado en el padrón AFIP"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RenaperResponse": {
        "type": "object",
        "title": "RenaperResponse",
        "required": ["dni", "nombre_completo", "cuil", "fecha_nacimiento", "domicilio"],
        "properties": {
          "dni": {
            "type": "string",
            "title": "DNI"
          },
          "nombre_completo": {
            "type": "string",
            "title": "Nombre completo"
          },
          "cuil": {
            "type": "string",
            "title": "CUIL"
          },
          "fecha_nacimiento": {
            "type": "string",
            "title": "Fecha de nacimiento",
            "description": "Formato YYYY-MM-DD"
          },
          "domicilio": {
            "type": "string",
            "title": "Domicilio registrado"
          }
        }
      },
      "BcraResponse": {
        "type": "object",
        "title": "BcraResponse",
        "required": ["cuil", "situacion", "score", "deudas_activas_pesos", "informes_negativos_12m"],
        "properties": {
          "cuil": {
            "type": "string",
            "title": "CUIL"
          },
          "situacion": {
            "type": "string",
            "title": "Situación crediticia",
            "description": "Ej: 1 - Normal, 2 - Riesgo bajo, etc."
          },
          "score": {
            "type": "integer",
            "title": "Score crediticio"
          },
          "deudas_activas_pesos": {
            "type": "integer",
            "title": "Deudas activas en pesos"
          },
          "informes_negativos_12m": {
            "type": "boolean",
            "title": "Informes negativos últimos 12 meses"
          }
        }
      },
      "AfipResponse": {
        "type": "object",
        "title": "AfipResponse",
        "required": ["cuil", "categoria", "estado", "fecha_inscripcion"],
        "properties": {
          "cuil": {
            "type": "string",
            "title": "CUIL"
          },
          "categoria": {
            "type": "string",
            "title": "Categoría tributaria",
            "description": "Valores posibles: relacion_dependencia, monotributista, autonomo"
          },
          "estado": {
            "type": "string",
            "title": "Estado fiscal"
          },
          "fecha_inscripcion": {
            "type": "string",
            "title": "Fecha de inscripción",
            "description": "Formato YYYY-MM-DD"
          },
          "empleador": {
            "type": "string",
            "title": "Empleador",
            "description": "Solo presente si la categoría es relacion_dependencia"
          },
          "actividad": {
            "type": "string",
            "title": "Actividad",
            "description": "Solo presente si la categoría es autonomo"
          },
          "categoria_monotributo": {
            "type": "string",
            "title": "Categoría de monotributo",
            "description": "Solo presente si la categoría es monotributista"
          }
        }
      }
    }
  }
}
